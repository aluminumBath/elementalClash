  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: michelle_raindancer_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: Michelle Raindancer
  Role: 'Blood Channeler Vizier in Wind Capital. Role: Villain.'
  Personality: Rule-bound, merciless, disciplined, and convinced order matters more
    than mercy.
  LocalKnowledge: I am usually found at Theocratic Rule Hall in Wind Capital. Serves
    as a harsh lieutenant/vizier within a capital power structure.
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: You should not have come here.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is Blood.
  - Keyword: family
    Response: Serves as a harsh lieutenant/vizier within a capital power structure.
  - Keyword: where
    Response: You can find me at Theocratic Rule Hall in Wind Capital.
  - Keyword: capital
    Response: The Wind Capital is strong because its people endure, learn, and build
      together.
