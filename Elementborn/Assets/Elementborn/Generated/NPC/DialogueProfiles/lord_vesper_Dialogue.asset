  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: lord_vesper_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: Lord Vesper
  Role: 'Cult Patron in Fire Region. Role: Villain.'
  Personality: Cold and manipulative.
  LocalKnowledge: I am usually found at Black Basalt Keep in Fire Region. Connected
    to hidden cult networks.
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: You should not have come here.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is Fire, with a trace of Shadow.
  - Keyword: family
    Response: Connected to hidden cult networks.
  - Keyword: where
    Response: You can find me at Black Basalt Keep in Fire Region.
  - Keyword: capital
    Response: The Fire Region is strong because its people endure, learn, and build
      together.
