  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: prince_consort_oren_ashmantle_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: Prince-Consort Oren Ashmantle
  Role: 'Prince-Consort and Master of the Furnace Guard in Fire Capital. Role: RoyalFamily.'
  Personality: Protective, disciplined, patient, and quietly affectionate.
  LocalKnowledge: I am usually found at Ember Hall in Fire Capital. Husband to Queen
    Seraphine; father of Kaelen and Lyra; trusted by the Furnace Guard and respected
    by Maelis.
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: The city survives because discipline stands beside passion. Remember
    that if you mean to stay near the caldera.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is Fire, with a trace of Metal.
  - Keyword: family
    Response: Husband to Queen Seraphine; father of Kaelen and Lyra; trusted by the
      Furnace Guard and respected by Maelis.
  - Keyword: where
    Response: You can find me at Ember Hall in Fire Capital.
  - Keyword: capital
    Response: The Fire Capital is strong because its people endure, learn, and build
      together.
