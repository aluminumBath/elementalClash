  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: first_mate_sarah_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: First Mate Sarah
  Role: 'First Mate in Neritha Reefwood. Role: Pirate.'
  Personality: Intelligent, deeply empathic, guarded, and unwilling to discuss her
    past.
  LocalKnowledge: "I am usually found at Raucous Tide - Main Deck in Neritha Reefwood.
    First mate to Captain Ram\xF3n. From the Wind Capital, but keeps it secret; only
    Ram\xF3n knows what happened."
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: Greetings. I am First Mate Sarah.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is Air.
  - Keyword: family
    Response: "First mate to Captain Ram\xF3n. From the Wind Capital, but keeps it
      secret; only Ram\xF3n knows what happened."
  - Keyword: where
    Response: You can find me at Raucous Tide - Main Deck in Neritha Reefwood.
  - Keyword: capital
    Response: The Neritha Reefwood is strong because its people endure, learn, and
      build together.
