  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: kelly_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: Kelly
  Role: 'Protective Lava Channeler in Fire Capital. Role: QuestGiver.'
  Personality: Kind, fiercely protective, lightly mischievous, and deeply loyal to
    friends and neighbors.
  LocalKnowledge: I am usually found at Basalt Row in Fire Capital. Acts as a neighborhood
    protector and potential ally for local residents.
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: Greetings. I am Kelly.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is Lava, with a trace of Fire.
  - Keyword: family
    Response: Acts as a neighborhood protector and potential ally for local residents.
  - Keyword: where
    Response: You can find me at Basalt Row in Fire Capital.
  - Keyword: capital
    Response: The Fire Capital is strong because its people endure, learn, and build
      together.
