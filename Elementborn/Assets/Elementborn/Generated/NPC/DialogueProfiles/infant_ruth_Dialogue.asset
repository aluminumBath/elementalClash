  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: infant_ruth_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: Ruth
  Role: 'Infant Heir in Wind Capital. Role: RoyalFamily.'
  Personality: Too young to judge, but already treated as a living omen by the faithful.
  LocalKnowledge: I am usually found at High Aerie Nursery in Wind Capital. Daughter
    of Redbeard and Lizkota. Her steam channeling is being interpreted as a divine
    sign.
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: Welcome. I am Ruth.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is Steam, with a trace of Air.
  - Keyword: family
    Response: Daughter of Redbeard and Lizkota. Her steam channeling is being interpreted
      as a divine sign.
  - Keyword: where
    Response: You can find me at High Aerie Nursery in Wind Capital.
  - Keyword: capital
    Response: The Wind Capital is strong because its people endure, learn, and build
      together.
