  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: howlj_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: Howlj
  Role: 'Anti-Channeler Agitator in Metal Capital. Role: Villain.'
  Personality: Narcissistic, jealous of secret channelers, resentful, and manipulative.
  LocalKnowledge: I am usually found at Backroom Salon in Metal Capital. Married
    to Larissa. He does not know she is secretly a metal channeler.
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: You should not have come here.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is None.
  - Keyword: family
    Response: Married to Larissa. He does not know she is secretly a metal channeler.
  - Keyword: where
    Response: You can find me at Backroom Salon in Metal Capital.
  - Keyword: capital
    Response: The Metal Capital is strong because its people endure, learn, and build
      together.
