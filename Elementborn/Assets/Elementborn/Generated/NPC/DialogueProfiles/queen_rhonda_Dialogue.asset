  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: queen_rhonda_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: Queen Rhonda
  Role: 'Queen of the Metal Capital in Metal Capital. Role: RoyalFamily.'
  Personality: Laissez-faire, charming, shrewd when she chooses to be, and hard to
    shock.
  LocalKnowledge: I am usually found at Chrome Court in Metal Capital. Married to
    King Randy; mother of Prince William aka Bubba.
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: Welcome. I am Queen Rhonda.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is Metal.
  - Keyword: family
    Response: Married to King Randy; mother of Prince William aka Bubba.
  - Keyword: where
    Response: You can find me at Chrome Court in Metal Capital.
  - Keyword: capital
    Response: The Metal Capital is strong because its people endure, learn, and build
      together.
