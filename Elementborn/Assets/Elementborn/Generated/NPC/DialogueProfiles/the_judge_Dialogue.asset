  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: the_judge_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: The Judge
  Role: 'Neon Pink Dragon Judge in Steam Territory. Role: Villain.'
  Personality: Harsh, territorial, protective, judgmental, and imposing.
  LocalKnowledge: I am usually found at Steam-Bright Perch in Steam Territory. Protects
    her area ruthlessly and considers trespass a crime.
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: You should not have come here.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is Steam.
  - Keyword: family
    Response: Protects her area ruthlessly and considers trespass a crime.
  - Keyword: where
    Response: You can find me at Steam-Bright Perch in Steam Territory.
  - Keyword: capital
    Response: The Steam Territory is strong because its people endure, learn, and
      build together.
