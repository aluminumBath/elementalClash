  m_Script: {fileID: 11500000, guid: 3b05ffcfd727c2c4794f71eaa4954ab5, type: 3}
  m_Name: priestess_lizkota_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::Elementborn.Game.NpcConversationProfile
  NpcName: Priestess Lizkota
  Role: 'Right-Hand Priestess in Wind Capital. Role: RoyalFamily.'
  Personality: Intelligent, disciplined, politically sharp, and intensely protective
    of her family.
  LocalKnowledge: I am usually found at High Aerie Cathedral in Wind Capital. Wife
    and right hand of High Priest Redbeard; mother of infant Ruth.
  Boundaries: Do not reveal hidden plot secrets unless the player has earned them
    through quests.
  Greeting: Welcome. I am Priestess Lizkota.
  UnknownResponse: That is not something I can speak on yet, but the city has many
    stories for those who listen.
  KeywordResponses:
  - Keyword: element
    Response: My element is Air.
  - Keyword: family
    Response: Wife and right hand of High Priest Redbeard; mother of infant Ruth.
  - Keyword: where
    Response: You can find me at High Aerie Cathedral in Wind Capital.
  - Keyword: capital
    Response: The Wind Capital is strong because its people endure, learn, and build
      together.
