  npcId: johna_rold
  displayName: Johna Rold
  npc: {fileID: 11400000, guid: 09316ac7438f364448b2b988cef02d14, type: 2}
  summary: Frequently seen smoking a pipe and offering advice. Good candidate for
    rumor routing, side quests, and neighborhood guidance.
  cues:
  - CueId: greeting
    TriggerKeyword: 
    Line: Sit. The smoke will leave before the worry does.
    JournalNote: Johna gives gentle advice.
    QuestToStart: {fileID: 0}
    Importance: 0
  - CueId: advice
    TriggerKeyword: advice
    Line: When a city gets loud, ask who benefits from the noise.
    JournalNote: Johna can steer the player toward political truth.
    QuestToStart: {fileID: 11400000, guid: fabba91c07c87a842bf384c4f5b13d08, type: 2}
    Importance: 1
  - CueId: sick
    TriggerKeyword: sick
    Line: A body can be weak and still carry useful words.
    JournalNote: Johna is sickly but wise.
    QuestToStart: {fileID: 0}
    Importance: 0
